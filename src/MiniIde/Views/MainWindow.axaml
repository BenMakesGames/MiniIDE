<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniIde.ViewModels"
        xmlns:m="using:MiniIde.Models"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        Width="1200" Height="800"
        x:Class="MiniIde.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MiniIde"
        Background="#1E1E22">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Menu Grid.Row="0" Background="#1E1E22">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Solution..." Click="OnOpenSolutionClick"/>
                <MenuItem Header="_Save" Click="OnSaveClick"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Find in Files" Click="OnFocusFindClick"/>
            </MenuItem>
            <MenuItem Header="_Navigate">
                <MenuItem Header="Go to _Definition (F12)" Click="OnGoToDefClick"/>
                <MenuItem Header="Find _References (Shift+F12)" Click="OnFindRefsClick"/>
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="_Play (F5)" Command="{Binding PlayCommand}"/>
                <MenuItem Header="_Stop" Command="{Binding StopCommand}"/>
            </MenuItem>
        </Menu>

        <DockPanel Grid.Row="1" Margin="4" Background="#1E1E22">
            <TextBlock DockPanel.Dock="Left" Text="Startup:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox DockPanel.Dock="Left" Width="280"
                      ItemsSource="{Binding Projects}"
                      SelectedItem="{Binding StartupProject}">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="m:ProjectEntry">
                        <TextBlock Text="{Binding Display}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button DockPanel.Dock="Left" Content="▶ Play" Margin="8,0,0,0" Command="{Binding PlayCommand}"/>
            <Button DockPanel.Dock="Left" Content="■ Stop" Margin="4,0,0,0" Command="{Binding StopCommand}"/>
            <TextBlock/>
        </DockPanel>

        <Grid Grid.Row="2" ColumnDefinitions="280,4,*">
            <TreeView Grid.Column="0" Background="#1E1E22" ItemsSource="{Binding Tree}" x:Name="SolutionTree" DoubleTapped="OnTreeDoubleTapped">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate DataType="m:TreeNode" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <GridSplitter Grid.Column="1" Background="#2D2D30"/>

            <Grid Grid.Column="2" RowDefinitions="*,4,220">
                <TabControl Grid.Row="0" Background="#1E1E22" ItemsSource="{Binding Tabs}" SelectedItem="{Binding ActiveTab}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="vm:EditorTabViewModel">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Header}"/>
                                <Button Content="✕" Margin="6,0,0,0" Padding="4,0" Click="OnCloseTabClick" Tag="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="vm:EditorTabViewModel">
                            <ae:TextEditor ShowLineNumbers="True"
                                           FontFamily="Consolas,monospace"
                                           FontSize="13"
                                           Background="#000000"
                                           Foreground="#DCDCDC"
                                           Name="Editor"
                                           AttachedToVisualTree="OnEditorAttached"
                                           DataContextChanged="OnEditorDataContextChanged"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <GridSplitter Grid.Row="1" Background="#2D2D30"/>

                <TabControl Grid.Row="2" Background="#1E1E22">
                    <TabItem Header="Find">
                        <Grid RowDefinitions="Auto,*,Auto" DataContext="{Binding Find}">
                            <DockPanel Grid.Row="0" Margin="4">
                                <CheckBox DockPanel.Dock="Right" Content="Regex" IsChecked="{Binding UseRegex}" Margin="6,0,0,0"/>
                                <Button DockPanel.Dock="Right" Content="Search" Command="{Binding SearchCommand}"/>
                                <TextBox x:Name="FindBox" Text="{Binding Query, Mode=TwoWay}" Watermark="Search..."
                                         KeyDown="OnFindKeyDown"/>
                            </DockPanel>
                            <ListBox Grid.Row="1" ItemsSource="{Binding Results}" SelectedItem="{Binding Selected}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="m:FindHit">
                                        <TextBlock>
                                            <Run Text="{Binding File}"/><Run Text=":"/><Run Text="{Binding Line}"/><Run Text=" — "/><Run Text="{Binding Preview}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="4"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Output">
                        <ListBox ItemsSource="{Binding Output.Lines}" FontFamily="Consolas,monospace"/>
                    </TabItem>

                    <TabItem Header="NuGet">
                        <Grid ColumnDefinitions="*,4,*,4,*" RowDefinitions="Auto,*,Auto" DataContext="{Binding NuGetVm}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project" Margin="4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Package (current)" Margin="4"/>
                            <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Margin="4">
                                <TextBlock Text="Versions" VerticalAlignment="Center"/>
                                <CheckBox Content="Prerelease" IsChecked="{Binding IncludePrerelease}" Margin="10,0,0,0"/>
                            </StackPanel>

                            <ListBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="m:ProjectEntry">
                                        <TextBlock Text="{Binding Display}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <GridSplitter Grid.Row="1" Grid.Column="1" Background="#2D2D30"/>
                            <ListBox Grid.Row="1" Grid.Column="2" ItemsSource="{Binding Packages}" SelectedItem="{Binding SelectedPackage}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="m:PackageEntry">
                                        <TextBlock>
                                            <Run Text="{Binding Id}"/><Run Text=" "/><Run Text="{Binding CurrentVersion}" FontStyle="Italic"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <GridSplitter Grid.Row="1" Grid.Column="3" Background="#2D2D30"/>
                            <ListBox Grid.Row="1" Grid.Column="4" ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}"/>

                            <DockPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Margin="4">
                                <Button DockPanel.Dock="Right" Content="Apply + Restore" Command="{Binding ApplyCommand}"/>
                                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="#1E1E22" BorderThickness="0,1,0,0" BorderBrush="#40808080" Padding="6,2">
            <TextBlock Text="{Binding Status}"/>
        </Border>
    </Grid>
</Window>
