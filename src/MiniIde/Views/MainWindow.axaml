<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniIde.ViewModels"
        xmlns:m="using:MiniIde.Models"
        xmlns:ae="using:AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        Width="1200" Height="800"
        x:Class="MiniIde.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Icon="/Assets/icon.ico"
        Background="#1E1E22">
    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="1" Background="#1E1E22" BorderThickness="0,0,0,1" BorderBrush="#40808080">
            <Grid Margin="8,4" ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding SolutionName}" VerticalAlignment="Center" FontSize="18" Background="Transparent" DoubleTapped="OnSolutionNameDoubleTapped">
                    <TextBlock.ContextMenu>
                        <ContextMenu Opening="OnSolutionCtxOpening">
                            <ContextMenu.Styles>
                                <!-- An explicit Foreground on the icon TextBlock overrides the theme's
                                     disabled-state dimming, so the glyph stays bright while the item's
                                     text greys out. Dim the whole item to keep icon + text in sync. -->
                                <Style Selector="MenuItem:disabled">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Style>
                            </ContextMenu.Styles>
                            <MenuItem Name="SolutionCtxOpenNew" Header="_Open solution..." Click="OnOpenSolutionClick"/>
                            <MenuItem Header="_Reload solution" Click="OnReloadSolutionClick">
                                <MenuItem.Icon>
                                    <TextBlock Text="{x:Static m:ActionIcon.Reload}" FontFamily="{StaticResource IconFont}" FontSize="16" Foreground="#3FB950" VerticalAlignment="Center"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Open in _Claude Code" Click="OnCtxOpenWithClaudeClick">
                                <MenuItem.Icon>
                                    <TextBlock Text="{x:Static m:ActionIcon.Claude}" FontFamily="{StaticResource IconFont}" FontSize="16" Foreground="#569CD6" VerticalAlignment="Center"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="_Open in Explorer" Click="OnCtxOpenInExplorerClick">
                                <MenuItem.Icon>
                                    <TextBlock Text="{x:Static m:ActionIcon.Explorer}" FontFamily="{StaticResource IconFont}" FontSize="16" Foreground="#E8C547" VerticalAlignment="Center"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Copy _absolute path" Click="OnCtxCopyAbsolutePathClick"/>
                            <MenuItem Header="Copy _relative path" Click="OnCtxCopyRelativePathClick"/>
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ComboBox Width="280"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding StartupProject}">
                        <ComboBox.Styles>
                            <Style Selector="ComboBoxItem" x:DataType="m:ProjectEntry">
                                <Setter Property="IsEnabled" Value="{Binding IsRunnable}"/>
                            </Style>
                            <Style Selector="ComboBoxItem:disabled">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Style>
                        </ComboBox.Styles>
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="m:ProjectEntry">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="16"
                                               Foreground="{Binding IconColor}"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="▶ Run" Margin="8,0,0,0" Command="{Binding PlayCommand}"/>
                    <Button Content="■ Stop" Margin="4,0,0,0" Command="{Binding StopCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" x:Name="Workspace">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <!-- MinHeight stops the splitter dragging the panel down to an unusable sliver. Collapsing drops
                     it to 0 so the 22px bar can undercut it, and restoring puts it back (MainWindow.axaml.cs). -->
                <RowDefinition Height="220" MinHeight="200"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" ColumnDefinitions="280,4,*">
                <TreeView Grid.Column="0" Background="#1E1E22" ItemsSource="{Binding Tree}" x:Name="SolutionTree">
                    <!-- Stretch the item so its header ContentPresenter fills the full row height. The Fluent
                         default is VerticalAlignment=Center, which leaves the presenter shorter than the row
                         (top/bottom dead strips). Horizontal is already Stretch and Padding already 0 in the
                         Fluent theme, so VerticalAlignment is the only lever needed. Avalonia's TreeViewItem
                         has no HorizontalContentAlignment/VerticalContentAlignment; the presenter template-binds
                         HorizontalAlignment/VerticalAlignment instead. -->
                    <TreeView.ItemContainerTheme>
                        <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                        </ControlTheme>
                    </TreeView.ItemContainerTheme>
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate DataType="m:TreeNode" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="_Open in Explorer" Click="OnCtxOpenInExplorerClick">
                                            <MenuItem.Icon>
                                                <TextBlock Text="{x:Static m:ActionIcon.Explorer}" FontFamily="{StaticResource IconFont}" FontSize="16" Foreground="#E8C547" VerticalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Copy _absolute path" Click="OnCtxCopyAbsolutePathClick"/>
                                        <MenuItem Header="Copy _relative path" Click="OnCtxCopyRelativePathClick"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="{Binding IconGlyph}"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="16"
                                           Foreground="{Binding IconColor}"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
                <GridSplitter Grid.Column="1" Background="#2D2D30"/>

                <TabControl Grid.Column="2" Background="#1E1E22" ItemsSource="{Binding Tabs}" SelectedItem="{Binding ActiveTab}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="vm:TabViewModelBase">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.ContextMenu>
                                    <!-- Path actions are inert on output tabs (no backing file); OnTabHeaderCtxOpening
                                         disables every item when the tab has no FilePath. -->
                                    <ContextMenu Opening="OnTabHeaderCtxOpening">
                                        <ContextMenu.Styles>
                                            <Style Selector="MenuItem:disabled">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Style>
                                        </ContextMenu.Styles>
                                        <MenuItem Header="_Open in Explorer" Click="OnCtxOpenInExplorerClick">
                                            <MenuItem.Icon>
                                                <TextBlock Text="{x:Static m:ActionIcon.Explorer}" FontFamily="{StaticResource IconFont}" FontSize="16" Foreground="#E8C547" VerticalAlignment="Center"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Copy _absolute path" Click="OnCtxCopyAbsolutePathClick"/>
                                        <MenuItem Header="Copy _relative path" Click="OnCtxCopyRelativePathClick"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <Button Content="✕" Margin="0,0,6,0" Padding="4,0" FontSize="10" MinHeight="0" MinWidth="0" Click="OnCloseTabClick" Tag="{Binding}"/>
                                <TextBlock Text="{Binding Header}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.DataTemplates>
                        <DataTemplate DataType="vm:EditorTabViewModel">
                            <ae:TextEditor IsReadOnly="True"
                                           ShowLineNumbers="True"
                                           FontFamily="Consolas,monospace"
                                           FontSize="13"
                                           Background="#000000"
                                           Foreground="#DCDCDC"
                                           Name="Editor"
                                           AttachedToVisualTree="OnEditorAttached"
                                           DataContextChanged="OnEditorDataContextChanged"
                                           DetachedFromVisualTree="OnEditorDetached">
                                <ae:TextEditor.ContextMenu>
                                    <ContextMenu Opening="OnCodeCtxOpening">
                                        <MenuItem Name="CtxSearchItem" Header="Search solution" InputGesture="Ctrl+Shift+F" Click="OnCtxSearchClick"/>
                                        <MenuItem Name="CtxFindUsagesItem" Header="Find usages" InputGesture="Shift+F12" Click="OnCtxFindUsagesClick"/>
                                        <MenuItem Name="CtxGoToDefItem" Header="Go to definition" InputGesture="F12" Click="OnCtxGoToDefClick"/>
                                        <Separator/>
                                        <MenuItem Name="CtxRenameItem" Header="Rename…" Click="OnCtxRenameClick"/>
                                    </ContextMenu>
                                </ae:TextEditor.ContextMenu>
                            </ae:TextEditor>
                        </DataTemplate>
                        <!-- Same three handlers as the code template: each binder ignores editors showing the
                             other kind of tab, so the window needs one handler trio, not one per kind. -->
                        <DataTemplate DataType="vm:OutputTabViewModel">
                            <ae:TextEditor IsReadOnly="True"
                                           ShowLineNumbers="False"
                                           WordWrap="False"
                                           FontFamily="Consolas,monospace"
                                           FontSize="13"
                                           Background="#000000"
                                           Foreground="#DCDCDC"
                                           AttachedToVisualTree="OnEditorAttached"
                                           DataContextChanged="OnEditorDataContextChanged"
                                           DetachedFromVisualTree="OnEditorDetached"/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:ImageTabViewModel">
                            <Grid Background="#1E1E22">
                                <Viewbox Stretch="Uniform"
                                         StretchDirection="DownOnly"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Image Source="{Binding Image}"/>
                                </Viewbox>
                                <TextBlock Text="{Binding Error}"
                                           Foreground="#DCDCDC"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            </Grid>
                        </DataTemplate>
                    </TabControl.DataTemplates>
                </TabControl>
            </Grid>

            <GridSplitter Grid.Row="1" Background="#2D2D30" x:Name="BottomSplitter"/>

            <!-- The toggle is a sibling of BottomTabs, not a child: TabControl has no header-area extension
                 point, and keeping the button out of BottomTabs' visual tree means the tunneling
                 restore-on-tab-click handler never sees the button's own press, so the two can't double-fire. -->
            <Grid Grid.Row="2">
                <TabControl Background="#1E1E22" x:Name="BottomTabs">
                    <TabItem Header="Find" x:Name="FindTab">
                        <Grid RowDefinitions="Auto,*,Auto" DataContext="{Binding Find}">
                            <DockPanel Grid.Row="0" Margin="4">
                                <CheckBox DockPanel.Dock="Right" Content="Regex" IsChecked="{Binding UseRegex}" Margin="6,0,0,0"/>
                                <CheckBox DockPanel.Dock="Right" Content="Case-sensitive" IsChecked="{Binding CaseSensitive}" Margin="6,0,0,0"/>
                                <Button DockPanel.Dock="Right" Content="Search" Command="{Binding SearchCommand}" Margin="6,0,0,0"/>
                                <TextBox x:Name="FindBox" Text="{Binding Query, Mode=TwoWay}" PlaceholderText="Search..."
                                         KeyDown="OnFindKeyDown"/>
                            </DockPanel>
                            <ListBox Grid.Row="1" Background="#000000" ItemsSource="{Binding Results}" SelectedItem="{Binding Selected}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="m:FindHit">
                                        <TextBlock>
                                            <Run Text="{Binding Location.File}"/><Run Text=":"/><Run Text="{Binding Location.Line}"/><Run Text=" — "/><Run Text="{Binding Preview}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="4"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="NuGet">
                        <Grid ColumnDefinitions="2*,4,3*,4,240" RowDefinitions="Auto,*,Auto" DataContext="{Binding NuGetVm}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project" Margin="4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Package (current)" Margin="4"/>
                            <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Margin="4">
                                <TextBlock Text="Versions" VerticalAlignment="Center"/>
                                <CheckBox Content="Prerelease" IsChecked="{Binding IncludePrerelease}" Margin="10,0,0,0"/>
                            </StackPanel>

                            <ListBox Grid.Row="1" Grid.Column="0" Background="#000000"
                                     x:Name="NuGetProjectsList"
                                     AttachedToVisualTree="OnNuGetListsAttached"
                                     ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="m:ProjectEntry">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="16"
                                                       Foreground="{Binding IconColor}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <GridSplitter Grid.Row="1" Grid.Column="1" Background="#2D2D30"/>
                            <ListBox Grid.Row="1" Grid.Column="2" Background="#000000"
                                     x:Name="NuGetPackagesList"
                                     ItemsSource="{Binding Packages}" SelectedItem="{Binding SelectedPackage}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="m:PackageEntry">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Id}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CurrentVersion}" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <GridSplitter Grid.Row="1" Grid.Column="3" Background="#2D2D30"/>
                            <ListBox Grid.Row="1" Grid.Column="4" Background="#000000"
                                     x:Name="NuGetVersionsList"
                                     ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}"/>

                            <DockPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Margin="4">
                                <Button DockPanel.Dock="Right" Content="Apply + Restore" Command="{Binding ApplyCommand}"/>
                                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Problems" x:Name="ProblemsTab">
                        <Grid RowDefinitions="Auto,*,Auto" DataContext="{Binding Problems}">
                            <Grid Grid.Row="0" Margin="4" ColumnDefinitions="Auto,*,Auto">
                                <Button Grid.Column="0" Content="Refresh" Command="{Binding RefreshCommand}"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton GroupName="ProblemGrouping" Content="By file" IsChecked="{Binding IsByFile, Mode=TwoWay}"/>
                                    <RadioButton GroupName="ProblemGrouping" Content="By code" IsChecked="{Binding IsByCode, Mode=TwoWay}" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1">
                                <TreeView Background="#000000" ItemsSource="{Binding Groups}"
                                          x:Name="ProblemsTree"
                                          AttachedToVisualTree="OnProblemsTreeAttached">
                                    <TreeView.ItemContainerTheme>
                                        <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                                        </ControlTheme>
                                    </TreeView.ItemContainerTheme>
                                    <TreeView.DataTemplates>
                                        <TreeDataTemplate DataType="vm:ProblemGroup" ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
                                        </TreeDataTemplate>
                                        <DataTemplate DataType="vm:ProblemLeaf">
                                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                                <TextBlock Text="{Binding Glyph}"
                                                           Foreground="{Binding IconColor}"
                                                           Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Display}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </TreeView.DataTemplates>
                                </TreeView>
                                <TextBlock Text="{Binding Placeholder}"
                                           Foreground="#808080"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           IsVisible="{Binding ShowPlaceholder}"/>
                            </Grid>
                            <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="4"/>
                        </Grid>
                    </TabItem>

                    <!-- Read-only observation of the OS-driven disk reconcile: it changes no behavior. Text-dense
                         and deliberately chart-free.

                         Laid out for the shape this panel actually is — wide and short. The counters are
                         fixed-width tiles in a WrapPanel, so they spend the abundant axis (horizontal) and
                         reflow into fewer columns as the window narrows, instead of stacking into a tall gutter
                         that scrolls while the right half sits empty. ItemWidth is the auto-repeating-column
                         knob: WrapPanel gives CSS's `repeat(auto-fill, 190px)`, not `minmax(190px, 1fr)` —
                         there is no stretch-to-fill, so the last column leaves a remainder. The real
                         minmax analogue is ItemsRepeater + UniformGridLayout MinItemWidth, which needs an
                         ItemsSource; these five tiles are heterogeneous static content, so it doesn't fit.

                         The log then takes the full width of the star row: its rows are the widest thing here
                         (time + kind + count + a path), and it's the part worth the space. -->
                    <TabItem Header="Disk" x:Name="DiskTab">
                        <Grid RowDefinitions="Auto,Auto,*" DataContext="{Binding DiskInsight}">
                            <DockPanel Grid.Row="0" Margin="4">
                                <Button DockPanel.Dock="Right" Content="Reset" Command="{Binding ResetCommand}"
                                        ToolTip.Tip="Rebase the counters and clear the log, to watch one burst"/>
                                <Panel DockPanel.Dock="Left" Width="8" Height="8" Margin="0,0,6,0"
                                       VerticalAlignment="Center">
                                    <Ellipse Fill="#4EC9B0" IsVisible="{Binding IsWatching}"/>
                                    <Ellipse Fill="#808080" IsVisible="{Binding !IsWatching}"/>
                                </Panel>
                                <TextBlock Text="{Binding WatchStatus}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>

                            <WrapPanel Grid.Row="1" Margin="4,0,4,4" ItemWidth="190">
                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="Feed" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Events seen"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EventsSeen}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Pruned"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EventsPruned}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Muted"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EventsMuted}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Signals raised"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SignalsRaised}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Overflows"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Overflows}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="Reconcile funnel" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Stat'd"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DocumentsStatted}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Read"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DocumentsRead}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ReadRatio}"
                                                   Foreground="#808080" Margin="6,0,0,0"
                                                   ToolTip.Tip="Read / stat'd — the stamp gate's payoff"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Forked"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DocumentsForked}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ForkRatio}"
                                                   Foreground="#808080" Margin="6,0,0,0"
                                                   ToolTip.Tip="Forked / read — content is the fork arbiter"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="Modes" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Drains"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Drains}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Full rescans"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FullRescans}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Structural reloads"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding StructuralReloads}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="Pending overlay" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Paths"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PendingCount}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Rescan queued"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NeedsFullRescan}"/>
                                    </Grid>
                                    <!-- Capped: an agent burst can leave dozens of paths pending, and the band
                                         must not grow to fit them and re-steal the log's height. -->
                                    <ScrollViewer MaxHeight="52" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding PendingPaths}" Foreground="#808080"/>
                                    </ScrollViewer>
                                </StackPanel>

                                <StackPanel Margin="0,0,12,8">
                                    <TextBlock Text="Open tabs" FontWeight="Bold" Margin="0,0,0,2"/>
                                    <ScrollViewer MaxHeight="70">
                                        <TextBlock Text="{Binding StaleTabs}" Foreground="#808080"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </WrapPanel>

                            <ListBox Grid.Row="2" Background="#000000" Margin="4,0,4,4"
                                     ItemsSource="{Binding Signals}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:DiskSignalRow">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                                            <TextBlock Grid.Column="0" Text="{Binding Time}" Foreground="#808080"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Kind}"
                                                       Foreground="{Binding KindColor}" Margin="10,0,0,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Paths}" Margin="10,0,0,0"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Detail}" Margin="10,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- The band is exactly as tall as the tab-header strip, so centering the toggle inside it lines the
                     glyph up with the tab labels. The strip shrinks with the row when collapsed, so the band has to
                     follow — code-behind sets its Height in the same two methods that own the collapse state.
                     (Binding this to a TabItem's Bounds doesn't work: the item keeps reporting its unclipped 48px
                     while the row is 22, which pushes the button past the bar's bottom edge.) -->
                <Grid x:Name="BottomPanelToggleBand"
                      HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="BottomPanelToggle" Content="▾"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0" Padding="4,0" MinHeight="0" MinWidth="0"
                            ToolTip.Tip="Collapse panel"
                            Click="OnToggleBottomPanelClick"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
